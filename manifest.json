{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "LoLProxChat",
    "author": "LoLProxChat",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.230.0",
    "minimum-gep-version": "0.230.0",
    "description": "Proximity voice chat for League of Legends",
    "dock_button_title": "LolProxChat",
    "icon": "icons/IconMouseOver.png",
    "icon_gray": "icons/IconMouseNormal.png"
  },
  "permissions": ["GameInfo", "Streaming", "DesktopStreaming", "Hotkeys", "Media", "Microphone"],
  "data": {
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [5426]
    },
    "start_window": "background",
    "enable_top_isolation": true,
    "windows": {
      "background": {
        "file": "background/background.html",
        "is_background_page": true
      },
      "overlay": {
        "file": "overlay/overlay.html",
        "transparent": true,
        "resizable": true,
        "topmost": true,
        "focus_game_takeover": "ReleaseOnLostFocus",
        "block_top_window_navigation": true,
        "override_on_update": true,
        "size": {
          "width": 590,
          "height": 350
        },
        "min_size": {
          "width": 140,
          "height": 140
        },
        "start_position": {
          "top": 730,
          "left": 1360
        }
      }
    },
    "hotkeys": {
      "push_to_talk": {
        "title": "Push to Talk",
        "action-type": "custom",
        "default": "V",
        "hold": true,
        "passthrough": true
      },
      "toggle_mute": {
        "title": "Toggle Self Mute",
        "action-type": "toggle",
        "default": "M"
      }
    },
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": {
          "game_ids": [5426]
        }
      }
    ]
  }
}
